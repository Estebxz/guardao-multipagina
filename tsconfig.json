{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"],
      "@hooks/*": ["app/hooks/*"],
      "@lib/*": ["app/lib/*"],
      "@common/*": ["app/components/common/*"],
      "@shell/*": ["app/components/shell/*"],
      "@type/*": ["app/types/*"],
      "@shared/*": ["app/components/shared/*"],
      "@ui/*": ["app/components/ui/*"],
      "@layout/*": ["app/components/layout/*"],
      "@icons/*": ["app/components/icons/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts"
  ],
  "exclude": ["node_modules"]
}
